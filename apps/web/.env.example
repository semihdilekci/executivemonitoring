# FastAPI backend base URL (client bundle'a dahil olur)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Ortam etiketi (development | production)
NEXT_PUBLIC_APP_ENV=development

# --- ngrok tek-URL demo paylaşımı (scripts/demo-share.sh) ------------------
# Bu üç değişken yalnızca demo paylaşımında gerekir; normal local dev'de boş
# bırakılır. Demo'da tarayıcı API'ye aynı origin'den (relative) gider; Next
# rewrite onu yerel FastAPI'ye proxy'ler.
#   NEXT_PUBLIC_API_BASE_URL=/api/v1               # tarayıcı → aynı origin
#   API_PROXY_TARGET=http://localhost:8000         # Next rewrite hedefi (server)
#   API_INTERNAL_BASE_URL=http://localhost:8000/api/v1  # auth route'ları (server)
