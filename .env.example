# Database — tüm komutlar (alembic, pytest, seed) bu URL'yi kullanır
DATABASE_URL=postgresql+asyncpg://postgres:SIFREN@localhost:5432/executivemonitoring_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000

# Pipeline runtime modu: "aws" (Lambda invoke + SQS gözlemi — deploy gerektirir) veya
# "local" (collector+processor in-process; yerel geliştirmede AWS/SQS gerektirmez).
PIPELINE_RUNTIME_MODE=aws

# LLM modeli artık "API Anahtarları" ekranında anahtar başına seçilir.
# Aşağıdaki env değişkenleri yalnızca model'i NULL olan eski kayıtlar için sessiz
# fallback'tir; normalde boş bırakılır (GROQ_MODEL / GEMINI_MODEL / ANTHROPIC_MODEL).
GEMINI_MODEL=gemini-2.5-flash-lite
ANTHROPIC_MODEL=claude-sonnet-4-6

# AWS (dev)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS resources (dev — CDK deploy outputs, Faz 0.6)
# Not: Bu blok aynı zamanda Lambda runtime env'idir (Faz 8.2 bundle).
# CDK deploy-time enjekte eder; lokal invoke için doldur (scripts/build_lambda.sh).
S3_ARCHIVE_BUCKET=
SQS_QUEUE_RSS_URL=
SQS_QUEUE_EMAIL_URL=
SQS_QUEUE_GOV_URL=
SQS_QUEUE_API_URL=

# LLM API key encryption (dev — local symmetric key)
ENCRYPTION_KEY=

# Mail (SMTP — dev: Gmail uygulama şifresi; prod: kurumsal relay)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Web uygulaması taban URL (digest bildirim linkleri)
WEB_BASE_URL=http://localhost:3000

# IMAP (Gmail newsletter collector — dev; şifre repo'ya commit edilmez)
# Seed script email kaynaklarına IMAP_HOST + IMAP_USER değerlerini yazar.
IMAP_HOST=imap.gmail.com
IMAP_USER=newsletter@example.com
IMAP_PASSWORD=

# FCM (Firebase service account — repo'ya commit edilmez)
FCM_SERVICE_ACCOUNT_PATH=
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Rate limits
RATE_LIMIT_AUTH_REFRESH=20
RATE_LIMIT_PASSWORD_RESET=3
RATE_LIMIT_CHATBOT=20

# Environment
ENVIRONMENT=development

# Embedding (processor chunker — OpenAI veya dev deterministic fallback)
OPENAI_API_KEY=
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_BATCH_SIZE=32

# Password reset (dev frontend URL)
PASSWORD_RESET_BASE_URL=http://localhost:3000/reset-password

# --- ngrok tek-URL demo paylaşımı (scripts/demo-share.sh) ------------------
# Lokal geliştirmeyi web üzerinden test ettirmek için. Sadece demo'da gerekir;
# normal local dev'de boş bırakılabilir.
# ngrok dashboard → Domains → "Create Domain" ile alınan ücretsiz statik domain.
# Çalıştırma:  NGROK_DOMAIN=your-name.ngrok-free.app  scripts/demo-share.sh
NGROK_DOMAIN=
# Opsiyonel port override (varsayılan 8000 / 3000)
API_PORT=8000
WEB_PORT=3000
